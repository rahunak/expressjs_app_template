            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signin/new_token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "signin",
                "new_token"
              ]
            },
            "description": "Refresh access token using refresh token. Old refresh token becomes invalid."
          },
          "response": []
        },
