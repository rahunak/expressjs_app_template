    {
      "name": "Files",
      "item": [
        {
          "name": "Upload File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('fileId', response.data.id);",
                  "    pm.environment.set('fileId', response.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/file/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "file",
                "upload"
              ]
            },
            "description": "Upload a new file. Select file in Body > form-data > file field."
          },
          "response": []
        },
        {
          "name": "Get File List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/file/list?page=1&list_size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "file",
                "list"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "list_size",
                  "value": "10",
                  "description": "Items per page (default: 10)"
                }
              ]
            },
            "description": "Get paginated list of files"
          },
          "response": []
        },
