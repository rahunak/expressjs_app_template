              "raw": "{{baseUrl}}/file/update/{{fileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "file",
                "update",
                "{{fileId}}"
              ]
            },
            "description": "Replace existing file with new one"
          },
          "response": []
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/file/delete/{{fileId}}",
